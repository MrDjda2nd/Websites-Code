<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>celestial.</title>
  <link rel="icon" href="https://ext.same-assets.com/1190468469/1048786454.png">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #0f0f0f;
      --bg-secondary: #1a1a1a;
      --bg-tertiary: #252525;
      --text: #d7d7d7;
      --text-muted: #848484;
      --border: #393939;
      --accent: #5b5b5b;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background-color: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow: hidden;
    }

    /* Navigation - Tab Bar */
    nav {
      background-color: var(--bg-secondary);
      display: flex;
      align-items: center;
      padding: 8px 12px;
      border-bottom: 1px solid var(--border);
    }

    #tabs {
      display: flex;
      align-items: center;
      gap: 4px;
      flex: 1;
    }

    .tab-item {
      display: flex;
      align-items: center;
      gap: 8px;
      background-color: var(--bg-tertiary);
      padding: 8px 12px;
      border-radius: 8px 8px 0 0;
      cursor: pointer;
      min-width: 120px;
      max-width: 200px;
      transition: background-color 0.2s;
    }

    .tab-item:hover {
      background-color: var(--accent);
    }

    .tab-item.active {
      background-color: var(--bg);
    }

    .tab-item .tab {
      font-size: 13px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      flex: 1;
    }

    .tab-item button {
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 16px;
      cursor: pointer;
      padding: 2px;
      line-height: 1;
      border-radius: 4px;
    }

    .tab-item button:hover {
      background-color: rgba(255,255,255,0.1);
      color: var(--text);
    }

    #new-tab-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 20px;
      cursor: pointer;
      padding: 8px;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #new-tab-btn:hover {
      background-color: var(--bg-tertiary);
      color: var(--text);
    }

    /* Tab Controls Bar */
    .tabthing {
      background-color: var(--bg);
      padding: 8px 12px;
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid var(--border);
    }

    #form {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .fc {
      background-color: var(--bg-tertiary);
      border: none;
      color: var(--text-muted);
      width: 32px;
      height: 32px;
      border-radius: 6px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      transition: all 0.2s;
    }

    .fc:hover {
      background-color: var(--accent);
      color: var(--text);
    }

    .fc i {
      font-size: 18px;
    }

    .url-bar {
      flex: 1;
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 8px 16px;
      color: var(--text);
      font-size: 14px;
      margin: 0 12px;
    }

    .url-bar:focus {
      outline: none;
      border-color: var(--accent);
    }

    /* Main Content Area */
    .main-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: calc(100vh - 100px);
      padding: 20px;
      position: relative;
    }

    .logo {
      width: 48px;
      height: 48px;
      position: absolute;
      top: 20px;
      left: 20px;
      opacity: 0.8;
    }

    .footer-links {
      position: absolute;
      bottom: 20px;
      right: 20px;
      display: flex;
      gap: 16px;
    }

    .footer-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 12px;
      transition: color 0.2s;
    }

    .footer-links a:hover {
      color: var(--text);
    }

    /* Update Log Modal */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: rgba(0, 0, 0, 0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }

    .modal-overlay.hidden {
      display: none;
    }

    .modal {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      width: 100%;
      max-width: 420px;
      padding: 24px;
      position: relative;
    }

    .modal-close {
      position: absolute;
      top: 16px;
      right: 16px;
      background: transparent;
      border: none;
      color: var(--text);
      font-size: 24px;
      cursor: pointer;
      line-height: 1;
    }

    .modal-close:hover {
      color: var(--text-muted);
    }

    .modal h2 {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 16px;
      text-align: center;
    }

    .modal-divider {
      height: 1px;
      background-color: var(--border);
      margin: 16px 0;
    }

    .modal h3 {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 12px;
      text-align: center;
    }

    .modal ul {
      list-style: none;
      padding: 0;
    }

    .modal li {
      font-size: 14px;
      color: var(--text);
      padding: 6px 0;
      border-bottom: 1px solid var(--border);
    }

    .modal li:last-child {
      border-bottom: none;
    }

    /* Settings Panel */
    #settings {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: var(--bg);
      z-index: 2000;
      display: none;
    }

    #settings.active {
      display: block;
    }

    .settings {
      display: flex;
      height: 100%;
    }

    #close {
      position: absolute;
      top: 15px;
      right: 15px;
      font-size: 40px;
      cursor: pointer;
      color: var(--text);
    }

    #sidenav {
      width: 220px;
      background-color: var(--bg-secondary);
      padding: 60px 16px 16px;
      border-right: 1px solid var(--border);
    }

    #sidenav a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      color: var(--text);
      text-decoration: none;
      border-radius: 8px;
      margin-bottom: 4px;
      transition: background-color 0.2s;
    }

    #sidenav a:hover {
      background-color: var(--bg-tertiary);
    }

    #sidenav a i {
      font-size: 20px;
    }

    .stuff {
      flex: 1;
      padding: 60px 40px;
      overflow-y: auto;
    }

    .box {
      background-color: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 16px;
    }

    .box h3 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .box .desc {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 12px;
    }

    .select {
      background-color: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 8px 12px;
      color: var(--text);
      font-size: 14px;
      cursor: pointer;
      width: 100%;
    }

    .box button {
      background-color: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 8px 16px;
      color: var(--text);
      font-size: 14px;
      cursor: pointer;
      margin-top: 12px;
      transition: background-color 0.2s;
    }

    .box button:hover {
      background-color: var(--accent);
    }

    /* Switch Toggle */
    .switch {
      position: relative;
      display: inline-block;
      width: 50px;
      height: 26px;
    }

    .switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: var(--bg-tertiary);
      border-radius: 26px;
      transition: 0.3s;
    }

    .slider:before {
      position: absolute;
      content: "";
      height: 20px;
      width: 20px;
      left: 3px;
      bottom: 3px;
      background-color: var(--text);
      border-radius: 50%;
      transition: 0.3s;
    }

    .switch input:checked + .slider {
      background-color: #4CAF50;
    }

    .switch input:checked + .slider:before {
      transform: translateX(24px);
    }

    /* Hide settings sections by default */
    .stuff > div {
      display: none;
    }

    .stuff > div.active {
      display: block;
    }
  </style>
</head>
<body data-theme="default">
  <!-- Navigation - Tabs -->
  <nav>
    <div id="tabs">
      <div class="tab-item active" data-tab-id="1">
        <span class="tab">new tab.</span>
        <button onclick="closeTab(this)">&times;</button>
      </div>
      <button id="new-tab-btn" onclick="addTab()">+</button>
    </div>
  </nav>

  <!-- Tab Controls -->
  <div class="tabthing">
    <form id="form">
      <a class="fc" onclick="goBack()" title="Back"><i class='bx bx-chevron-left'></i></a>
      <a class="fc" onclick="reload()" title="Reload"><i class='bx bx-refresh'></i></a>
      <a class="fc" onclick="goForward()" title="Forward"><i class='bx bx-chevron-right'></i></a>
    </form>
    <input type="text" class="url-bar" id="urlBar" value="celestial://newtab" placeholder="Search or enter URL...">
    <a class="fc" onclick="inspect()" title="Inspect"><i class='bx bx-code-alt'></i></a>
    <a class="fc" onclick="toggleFullscreen()" title="Fullscreen"><i class='bx bx-fullscreen'></i></a>
    <a class="fc" onclick="openSettings()" title="Settings"><i class='bx bx-dots-vertical-rounded'></i></a>
  </div>

  <!-- Main Content -->
  <div class="main-content">
    <img src="https://ext.same-assets.com/1190468469/1048786454.png" alt="Celestial Logo" class="logo">
    
    <div class="footer-links">
      <a href="#">about</a>
      <a href="#">legal</a>
      <a href="#">partners</a>
    </div>
  </div>

  <!-- Update Log Modal -->
  <div class="modal-overlay" id="updateModal">
    <div class="modal">
      <button class="modal-close" onclick="closeModal()">&times;</button>
      <h2>update log 03/23</h2>
      <div class="modal-divider"></div>
      <h3>media</h3>
      <ul>
        <li>- added AI (duck.ai)</li>
        <li>- the virtual machine is located in media</li>
      </ul>
      <div class="modal-divider"></div>
      <h3>games</h3>
      <ul>
        <li>- added the REAL hollow knight silksong</li>
        <li>- added rain world</li>
      </ul>
      <div class="modal-divider"></div>
    </div>
  </div>

  <!-- Settings Panel -->
  <div id="settings">
    <div class="settings">
      <p id="close" onclick="closeSettings()"><i class='bx bx-x'></i></p>
      <div id="sidenav">
        <a href="#" onclick="showSection('cloak')"><i class='bx bxs-ghost'></i> Cloaking</a>
        <a href="#" onclick="showSection('browsing')"><i class='bx bx-globe'></i> Proxy</a>
        <a href="#" onclick="showSection('appear')"><i class='bx bxs-palette'></i> Appearance</a>
        <a href="#" onclick="showSection('ext')"><i class='bx bx-plug'></i> Extensions</a>
        <a href="#" onclick="showSection('misc')"><i class='bx bxs-help-circle'></i> Miscellaneous</a>
      </div>
      <div class="stuff">
        <!-- Cloaking Section -->
        <div id="cloak" class="active">
          <div class="box">
            <h3>Cloaking Options</h3>
            <p class="desc">Choose between about:blank, about:blank buffed (recommended), and blob strings to stop teachers from seeing your screen & hiding your history.</p>
            <select class="select" id="cloakSelect">
              <option value="ab">about:blank</option>
              <option value="abbuff" selected>about:blank [buffed]</option>
              <option value="blob">blob: string</option>
            </select>
            <button onclick="launchCloak()">open</button>
          </div>
          <div class="box">
            <h3>Auto Cloak</h3>
            <p class="desc">Opens the cloak selected automatically</p>
            <label class="switch">
              <input type="checkbox" id="cloakTog">
              <span class="slider"></span>
            </label>
          </div>
          <div class="box">
            <h3>Tab Cloaking</h3>
            <p class="desc">Masks the tab as another tab to fool teachers</p>
            <select class="select" id="tabCloak">
              <option value="" selected>none</option>
              <option value="google">google</option>
              <option value="schoology">schoology</option>
              <option value="khan">khan academy</option>
              <option value="clever">clever</option>
              <option value="gc">google classroom</option>
              <option value="nt">new tab</option>
            </select>
          </div>
        </div>

        <!-- Browsing/Proxy Section -->
        <div id="browsing">
          <div class="box">
            <h3>Transport</h3>
            <p class="desc">Change how the proxy is handled</p>
            <select class="select" id="tselect">
              <option value="epoxy">epoxy</option>
              <option value="libcurl" selected>libcurl</option>
            </select>
          </div>
          <div class="box">
            <h3>Proxy</h3>
            <p class="desc">Same as the transport, can make proxy more stable</p>
            <select class="select" id="proxySelect">
              <option value="violet">ultraviolet</option>
              <option value="scram" selected>scramjet</option>
            </select>
          </div>
        </div>

        <!-- Appearance Section -->
        <div id="appear">
          <div class="box">
            <h3>Themes</h3>
            <p class="desc">Customize the color scheme of celestial</p>
            <select class="select" id="themepicker">
              <option value="default" selected>default</option>
              <option value="light">light</option>
              <option value="midnight">midnight blue</option>
              <option value="mocha">mocha</option>
              <option value="quasar">quasar</option>
              <option value="ccm">catppuccin mocha</option>
              <option value="frappe">catppuccin frappe</option>
            </select>
          </div>
        </div>

        <!-- Extensions Section -->
        <div id="ext">
          <div class="box">
            <h3>Extensions</h3>
            <p class="desc">Insert custom scripts into sites you visit. Kinda like bookmarklets.</p>
          </div>
        </div>

        <!-- Miscellaneous Section -->
        <div id="misc">
          <div class="box">
            <h3>Export Data</h3>
            <p class="desc">Transfer your data to another celestial instance.</p>
            <button>export</button>
            <button>import</button>
          </div>
          <div class="box">
            <h3>Contact Us</h3>
            <p class="desc">To contact us, you can send an email or send a message on discord!</p>
            <p style="font-size: 13px; margin-top: 8px;">email: celestialmaininq@gmail.com</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Tab Management
    let tabCount = 1;

    function addTab() {
      tabCount++;
      const tabs = document.getElementById('tabs');
      const newTab = document.createElement('div');
      newTab.className = 'tab-item';
      newTab.dataset.tabId = tabCount;
      newTab.innerHTML = `
        <span class="tab">new tab.</span>
        <button onclick="closeTab(this)">&times;</button>
      `;
      newTab.onclick = function(e) {
        if (e.target.tagName !== 'BUTTON') {
          setActiveTab(this);
        }
      };
      tabs.insertBefore(newTab, document.getElementById('new-tab-btn'));
      setActiveTab(newTab);
    }

    function closeTab(btn) {
      const tab = btn.parentElement;
      const tabs = document.querySelectorAll('.tab-item');
      if (tabs.length > 1) {
        if (tab.classList.contains('active')) {
          const index = Array.from(tabs).indexOf(tab);
          const nextTab = tabs[index + 1] || tabs[index - 1];
          setActiveTab(nextTab);
        }
        tab.remove();
      }
    }

    function setActiveTab(tab) {
      document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
    }

    // Add click handler to existing tab
    document.querySelector('.tab-item').onclick = function(e) {
      if (e.target.tagName !== 'BUTTON') {
        setActiveTab(this);
      }
    };

    // Navigation Functions
    function goBack() { console.log('Going back...'); }
    function goForward() { console.log('Going forward...'); }
    function reload() { console.log('Reloading...'); }
    function inspect() { console.log('Opening inspector...'); }
    
    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen();
      } else {
        document.exitFullscreen();
      }
    }

    // Modal Functions
    function closeModal() {
      document.getElementById('updateModal').classList.add('hidden');
    }

    // Settings Functions
    function openSettings() {
      document.getElementById('settings').classList.add('active');
    }

    function closeSettings() {
      document.getElementById('settings').classList.remove('active');
    }

    function showSection(sectionId) {
      document.querySelectorAll('.stuff > div').forEach(s => s.classList.remove('active'));
      document.getElementById(sectionId).classList.add('active');
      return false;
    }

    function launchCloak() {
      const select = document.getElementById('cloakSelect');
      alert('Launching cloak: ' + select.value + '\n\n(This is a demo clone)');
    }

    // URL Bar
    document.getElementById('urlBar').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        alert('Navigating to: ' + this.value + '\n\n(This is a demo clone)');
      }
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeSettings();
        closeModal();
      }
    });
  </script>
</body>
</html>
