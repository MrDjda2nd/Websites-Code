<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Phenix</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--orange:#FF5C00;--orange-hot:#FF8A00;--orange-deep:#C93D00;--cream:#FFF7F0;--dark:#0E0800;--dark2:#1A0F00;--dark3:#2B1800;--muted:#8A6040;--card:#160c00}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--cream);cursor:none}

.cursor{width:11px;height:11px;background:var(--orange);border-radius:50%;position:fixed;pointer-events:none;z-index:9999;transform:translate(-50%,-50%)}
.cursor-ring{width:34px;height:34px;border:1.5px solid var(--orange);border-radius:50%;position:fixed;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);opacity:.4;transition:left .18s ease,top .18s ease}

.fire-bg{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.ember{position:absolute;bottom:-10px;border-radius:50%;animation:riseEmber linear infinite;opacity:0}
@keyframes riseEmber{0%{transform:translateY(0) translateX(0) scale(1);opacity:.8}50%{opacity:.3;transform:translateY(-45vh) translateX(var(--dx)) scale(.55)}100%{transform:translateY(-105vh) translateX(var(--dx2)) scale(0);opacity:0}}

/* ── ONBOARDING ── */
#onboarding{position:fixed;inset:0;z-index:500;display:flex;align-items:center;justify-content:center;background:var(--dark);transition:opacity .5s}
#onboarding::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 85%,rgba(255,92,0,.2) 0%,transparent 68%);pointer-events:none}

.ob-screen{display:none;flex-direction:column;align-items:center;justify-content:center;gap:1.4rem;text-align:center;width:100%;max-width:500px;padding:2rem;position:relative;z-index:1;animation:obIn .5s ease both}
.ob-screen.active{display:flex}
@keyframes obIn{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

.splash-logo{font-family:'Bebas Neue',sans-serif;font-size:clamp(5rem,20vw,10rem);letter-spacing:.15em;color:var(--orange);text-shadow:0 0 80px rgba(255,92,0,.6),0 0 180px rgba(255,92,0,.22);line-height:1;animation:pulseGlow 2.8s ease-in-out infinite}
@keyframes pulseGlow{0%,100%{text-shadow:0 0 80px rgba(255,92,0,.6),0 0 180px rgba(255,92,0,.22)}50%{text-shadow:0 0 130px rgba(255,92,0,.9),0 0 260px rgba(255,92,0,.4)}}
.splash-tagline{font-family:'Syne',sans-serif;font-size:.75rem;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);margin-top:-.5rem}
.splash-cta{font-size:.82rem;color:var(--muted);animation:blink 1.5s ease-in-out infinite;margin-top:.25rem}
.splash-skip{font-size:.68rem;color:rgba(138,96,64,.45)}
.splash-skip kbd{background:rgba(255,92,0,.12);border:1px solid rgba(255,92,0,.28);padding:.1rem .4rem;border-radius:2px;font-size:.65rem;color:var(--orange)}
@keyframes blink{0%,100%{opacity:.5}50%{opacity:1}}

.ob-heading{font-family:'Bebas Neue',sans-serif;font-size:2.6rem;letter-spacing:.08em}
.ob-heading span{color:var(--orange)}
.ob-input{background:rgba(255,255,255,.04);border:1px solid rgba(255,92,0,.28);border-radius:4px;padding:.85rem 1.2rem;font-family:'DM Sans',sans-serif;font-size:1.05rem;color:var(--cream);outline:none;width:100%;text-align:center;transition:border-color .2s,box-shadow .2s}
.ob-input::placeholder{color:var(--muted)}
.ob-input:focus{border-color:var(--orange);box-shadow:0 0 0 3px rgba(255,92,0,.13)}
.ob-btn{font-family:'Syne',sans-serif;font-size:.8rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:var(--orange);color:var(--dark);border:none;padding:.88rem 2.6rem;border-radius:3px;cursor:none;transition:all .18s}
.ob-btn:hover{background:var(--orange-hot);transform:translateY(-2px);box-shadow:0 10px 28px rgba(255,92,0,.4)}
.ob-btn:disabled{opacity:.35;transform:none;box-shadow:none}

.bg-pick-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;width:100%}
.bg-opt{aspect-ratio:16/9;border-radius:6px;overflow:hidden;border:2px solid transparent;cursor:none;transition:all .2s;display:flex;align-items:center;justify-content:center;font-size:2rem;position:relative}
.bg-opt:hover{border-color:rgba(255,92,0,.45);transform:scale(1.04)}
.bg-opt.sel{border-color:var(--orange);box-shadow:0 0 0 3px rgba(255,92,0,.22)}
.bg-opt.sel::after{content:'✦';position:absolute;top:6px;right:8px;font-size:.65rem;color:var(--orange)}

.ready-bird{font-size:4rem;animation:bob .9s ease-in-out infinite alternate}
@keyframes bob{from{transform:translateY(0)}to{transform:translateY(-12px)}}
.ready-name{font-family:'Bebas Neue',sans-serif;font-size:3.2rem;color:var(--orange);letter-spacing:.1em}

/* ── APP SHELL ── */
#app{display:none;position:fixed;inset:0;z-index:10;flex-direction:column}
#app.show{display:flex}

.marquee-bar{background:var(--orange);overflow:hidden;padding:.5rem 0;flex-shrink:0;position:relative;z-index:2}
.marquee-track{display:flex;animation:ticker 32s linear infinite;white-space:nowrap}
.m-item{font-family:'Bebas Neue',sans-serif;font-size:.95rem;letter-spacing:.15em;color:var(--dark);padding:0 2rem;display:inline-flex;align-items:center;gap:2rem}
.m-item::after{content:'✦';font-size:.5rem}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

.app-body{display:flex;flex:1;overflow:hidden}

/* sidebar */
.sidebar{width:210px;flex-shrink:0;background:rgba(12,6,0,.98);border-right:1px solid rgba(255,92,0,.07);display:flex;flex-direction:column;overflow:hidden}
.sb-logo{font-family:'Bebas Neue',sans-serif;font-size:1.75rem;letter-spacing:.14em;color:var(--orange);text-shadow:0 0 18px rgba(255,92,0,.35);padding:1rem 1.2rem .85rem;border-bottom:1px solid rgba(255,92,0,.07);flex-shrink:0}
.sb-logo b{color:var(--cream);font-weight:400}
.sb-user{display:flex;align-items:center;gap:.6rem;padding:.75rem 1.2rem;border-bottom:1px solid rgba(255,92,0,.06);flex-shrink:0}
.sb-av{width:28px;height:28px;border-radius:50%;background:var(--orange);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:.95rem;color:var(--dark);flex-shrink:0}
.sb-uname{font-family:'Syne',sans-serif;font-size:.76rem;font-weight:700;color:var(--cream);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sb-nav{flex:1;overflow-y:auto;padding:.4rem 0}
.sb-nav::-webkit-scrollbar{width:3px}
.sb-nav::-webkit-scrollbar-thumb{background:rgba(255,92,0,.18);border-radius:99px}
.sb-sec{font-family:'Syne',sans-serif;font-size:.58rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(138,96,64,.45);padding:.7rem 1.2rem .3rem}
.sb-item{display:flex;align-items:center;gap:.65rem;padding:.52rem 1.2rem;font-size:.8rem;color:var(--muted);cursor:none;transition:all .14s;border-left:2px solid transparent;user-select:none}
.sb-item:hover{color:var(--cream);background:rgba(255,92,0,.05)}
.sb-item.on{color:var(--orange);border-left-color:var(--orange);background:rgba(255,92,0,.07)}
.sb-item .ico{font-size:.95rem;flex-shrink:0;width:18px;text-align:center}

/* top bar */
.topbar{display:flex;align-items:center;gap:.85rem;padding:.65rem 1.4rem;background:rgba(12,6,0,.96);border-bottom:1px solid rgba(255,92,0,.07);flex-shrink:0}
.srch{display:flex;align-items:center;gap:.5rem;background:rgba(255,255,255,.04);border:1px solid rgba(255,92,0,.12);border-radius:3px;padding:.42rem .85rem;flex:1;max-width:320px}
.srch input{background:none;border:none;outline:none;font-family:'DM Sans',sans-serif;font-size:.82rem;color:var(--cream);width:100%}
.srch input::placeholder{color:var(--muted)}
.tb-btn{font-family:'Syne',sans-serif;font-size:.65rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;background:rgba(255,92,0,.09);border:1px solid rgba(255,92,0,.2);color:var(--orange);padding:.38rem .85rem;border-radius:3px;cursor:none;transition:all .14s;margin-left:auto}
.tb-btn:hover{background:rgba(255,92,0,.18)}

/* content */
.right{flex:1;display:flex;flex-direction:column;overflow:hidden}
.content{flex:1;overflow-y:auto;background:var(--dark)}
.content::-webkit-scrollbar{width:5px}
.content::-webkit-scrollbar-thumb{background:rgba(255,92,0,.14);border-radius:99px}
.page{display:none;padding:1.4rem}
.page.on{display:block}

/* game iframe */
#gview{display:none;flex-direction:column;flex:1}
#gview.on{display:flex}
.gbar{display:flex;align-items:center;gap:.7rem;padding:.55rem 1.2rem;background:rgba(12,6,0,.99);border-bottom:1px solid rgba(255,92,0,.08);flex-shrink:0}
.gbar-back{font-family:'Syne',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--orange);background:none;border:1px solid rgba(255,92,0,.28);border-radius:3px;padding:.38rem .85rem;cursor:none;transition:all .14s}
.gbar-back:hover{background:rgba(255,92,0,.1)}
.gbar-title{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:.08em}
.gbar-fs{margin-left:auto;font-family:'Syne',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);background:none;border:1px solid rgba(255,255,255,.07);border-radius:3px;padding:.38rem .85rem;cursor:none;transition:all .14s}
.gbar-fs:hover{color:var(--cream);border-color:rgba(255,255,255,.18)}
#gframe{flex:1;border:none;background:#000;width:100%}

/* section headings */
.sh{display:flex;align-items:baseline;gap:.6rem;margin-bottom:.9rem;margin-top:1.4rem}
.sh:first-child{margin-top:0}
.sh-label{font-family:'Syne',sans-serif;font-size:.66rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--orange)}
.sh-sub{font-size:.7rem;color:var(--muted)}

/* featured banner */
.feat-card{position:relative;border-radius:8px;overflow:hidden;cursor:none;aspect-ratio:21/8;background:var(--dark3);border:1px solid rgba(255,92,0,.12);display:flex;align-items:flex-end;transition:border-color .2s;margin-bottom:1.6rem}
.feat-card:hover{border-color:rgba(255,92,0,.38)}
.feat-card:hover .fp{opacity:1;transform:scale(1)}
.feat-bg{position:absolute;inset:0;font-size:9rem;display:flex;align-items:center;justify-content:center;opacity:.1}
.feat-grad{position:absolute;inset:0;background:linear-gradient(to top,rgba(14,8,0,.97) 0%,rgba(14,8,0,.38) 55%,transparent 100%)}
.feat-info{position:relative;z-index:2;padding:1.4rem;display:flex;align-items:flex-end;justify-content:space-between;width:100%}
.feat-badge{display:inline-block;font-family:'Syne',sans-serif;font-size:.58rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;background:var(--orange);color:var(--dark);padding:.22rem .65rem;border-radius:2px;margin-bottom:.45rem}
.feat-name{font-family:'Bebas Neue',sans-serif;font-size:2.6rem;letter-spacing:.04em;line-height:1}
.feat-genre{font-size:.76rem;color:var(--muted);margin-top:.15rem}
.fp{background:var(--orange);color:var(--dark);font-family:'Syne',sans-serif;font-size:.72rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;border:none;padding:.75rem 1.6rem;border-radius:3px;cursor:none;opacity:0;transform:scale(.88);transition:all .2s}

/* game grid */
.ggrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:11px;margin-bottom:2rem}
.gc{background:var(--card);border:1px solid rgba(255,92,0,.07);border-radius:6px;overflow:hidden;cursor:none;transition:all .2s;position:relative}
.gc:hover{border-color:rgba(255,92,0,.32);transform:translateY(-3px);box-shadow:0 12px 26px rgba(0,0,0,.55)}
.gc:hover .gc-play{opacity:1}
.gc-thumb{width:100%;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;font-size:3rem;background:var(--dark3);position:relative}
.gc-thumb::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,92,0,.05),transparent)}
.gc-play{position:absolute;inset:0;background:rgba(10,5,0,.76);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .17s}
.gc-playbtn{width:42px;height:42px;background:var(--orange);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;transform:scale(.82);transition:transform .14s}
.gc:hover .gc-playbtn{transform:scale(1)}
.gc-info{padding:.6rem .7rem .7rem}
.gc-name{font-family:'Syne',sans-serif;font-size:.76rem;font-weight:700;color:var(--cream);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.gc-tag{font-size:.64rem;color:var(--muted);margin-top:.12rem}
.gc-hot{position:absolute;top:7px;right:7px;background:var(--orange);color:var(--dark);font-family:'Syne',sans-serif;font-size:.52rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;padding:.16rem .48rem;border-radius:2px}

/* category pills */
.cpills{display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:1.3rem}
.cpill{font-family:'Syne',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:.38rem .95rem;border-radius:999px;border:1px solid rgba(255,92,0,.17);background:transparent;color:var(--muted);cursor:none;transition:all .14s}
.cpill:hover,.cpill.on{background:var(--orange);border-color:var(--orange);color:var(--dark)}

/* settings */
.sset{background:var(--card);border:1px solid rgba(255,92,0,.08);border-radius:8px;padding:1.4rem;margin-bottom:1.1rem}
.sset-title{font-family:'Syne',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--orange);margin-bottom:.9rem}
.srow{display:flex;align-items:center;justify-content:space-between;padding:.55rem 0;border-bottom:1px solid rgba(255,92,0,.05);font-size:.83rem;color:var(--muted)}
.srow:last-of-type{border-bottom:none}
.srow span{color:var(--cream);font-weight:500}
.s-input{background:rgba(255,255,255,.05);border:1px solid rgba(255,92,0,.2);border-radius:3px;padding:.42rem .8rem;font-family:'DM Sans',sans-serif;font-size:.83rem;color:var(--cream);outline:none;transition:border-color .18s}
.s-input:focus{border-color:var(--orange)}
.sbtn{font-family:'Syne',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:var(--orange);color:var(--dark);border:none;padding:.48rem 1.1rem;border-radius:3px;cursor:none;transition:all .14s;margin-top:.7rem}
.sbtn:hover{background:var(--orange-hot);transform:translateY(-1px)}
.bg-grid-s{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;margin-top:.3rem}
.bgo{aspect-ratio:16/9;border-radius:4px;border:2px solid transparent;cursor:none;transition:all .17s;display:flex;align-items:center;justify-content:center;font-size:1.4rem}
.bgo:hover{border-color:rgba(255,92,0,.4);transform:scale(1.05)}
.bgo.sel{border-color:var(--orange);box-shadow:0 0 0 2px rgba(255,92,0,.22)}
</style>
</head>
<body>

<div class="cursor" id="C"></div>
<div class="cursor-ring" id="CR"></div>
<div class="fire-bg" id="FB"></div>

<!-- ════════════════════════════
     ONBOARDING
════════════════════════════ -->
<div id="onboarding">

  <!-- 0: Splash -->
  <div class="ob-screen active" id="ob0">
    <div class="splash-logo">PHENIX</div>
    <div class="splash-tagline">Game Portal</div>
    <div class="splash-cta">Click anywhere to begin</div>
    <div class="splash-skip">hold <kbd>Alt</kbd> to skip</div>
  </div>

  <!-- 1: Name -->
  <div class="ob-screen" id="ob1">
    <div class="ob-heading">What's your <span>name?</span></div>
    <input class="ob-input" id="nIn" type="text" placeholder="Enter your name…" maxlength="20" autocomplete="off">
    <button class="ob-btn" id="nBtn" disabled onclick="toOb2()">Continue →</button>
  </div>

  <!-- 2: Background -->
  <div class="ob-screen" id="ob2">
    <div class="ob-heading">Choose a <span>background</span></div>
    <div style="font-size:.78rem;color:var(--muted);margin-top:-.4rem">More options in Settings</div>
    <div class="bg-pick-grid" id="bgPick"></div>
    <button class="ob-btn" onclick="toOb3()">Continue →</button>
  </div>

  <!-- 3: Ready -->
  <div class="ob-screen" id="ob3">
    <div class="ready-bird">🔥</div>
    <div class="ob-heading">You're <span>All Set!</span></div>
    <div class="ready-name" id="rName">PLAYER</div>
    <div style="font-size:.82rem;color:var(--muted)">The portal is ready. Let's go.</div>
    <button class="ob-btn" onclick="enterApp()">Enter Phenix →</button>
  </div>

</div>

<!-- ════════════════════════════
     APP
════════════════════════════ -->
<div id="app">
  <div class="marquee-bar"><div class="marquee-track" id="mTrk"></div></div>
  <div class="app-body">

    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="sb-logo">PHEN<b>IX</b></div>
      <div class="sb-user">
        <div class="sb-av" id="sbAv">P</div>
        <div class="sb-uname" id="sbN">Player</div>
      </div>
      <nav class="sb-nav">
        <div class="sb-sec">Browse</div>
        <div class="sb-item on"  onclick="nav('home',this)"><span class="ico">🏠</span>Home</div>
        <div class="sb-item"     onclick="nav('all',this)"><span class="ico">🎮</span>All Games</div>
        <div class="sb-item"     onclick="nav('hot',this)"><span class="ico">🔥</span>Hot Right Now</div>
        <div class="sb-sec">Categories</div>
        <div class="sb-item"     onclick="nav('action',this)"><span class="ico">⚔️</span>Action</div>
        <div class="sb-item"     onclick="nav('racing',this)"><span class="ico">🏎️</span>Racing</div>
        <div class="sb-item"     onclick="nav('sports',this)"><span class="ico">🏈</span>Sports</div>
        <div class="sb-item"     onclick="nav('puzzle',this)"><span class="ico">🧩</span>Puzzle</div>
        <div class="sb-item"     onclick="nav('io',this)"><span class="ico">🌐</span>.io Games</div>
        <div class="sb-item"     onclick="nav('idle',this)"><span class="ico">🍪</span>Idle / Clicker</div>
        <div class="sb-item"     onclick="nav('classic',this)"><span class="ico">🕹️</span>Classic</div>
        <div class="sb-sec">Account</div>
        <div class="sb-item"     onclick="nav('settings',this)"><span class="ico">⚙️</span>Settings</div>
      </nav>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right">
      <div class="topbar">
        <div class="srch">
          <svg width="13" height="13" fill="none" stroke="var(--muted)" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" placeholder="Search games…" oninput="doSearch(this.value)">
        </div>
        <button class="tb-btn" onclick="nav('settings',null)">🎨 Theme</button>
      </div>

      <div class="content" id="content">

        <!-- HOME -->
        <div class="page on" id="page-home">
          <div class="feat-card" id="featCard">
            <div class="feat-bg" id="featBg"></div>
            <div class="feat-grad"></div>
            <div class="feat-info">
              <div>
                <div class="feat-badge">🔥 Featured Game</div>
                <div class="feat-name" id="featName">SLOPE</div>
                <div class="feat-genre" id="featGenre">Endless Runner · Skill</div>
              </div>
              <button class="fp" id="fpBtn">Play Now →</button>
            </div>
          </div>
          <div class="sh"><span class="sh-label">🔥 Popular</span><span class="sh-sub">All-time favorites</span></div>
          <div class="ggrid" id="g-home"></div>
          <div class="sh"><span class="sh-label">✨ New Picks</span></div>
          <div class="ggrid" id="g-new"></div>
        </div>

        <!-- ALL -->
        <div class="page" id="page-all">
          <div class="sh"><span class="sh-label">All Games</span></div>
          <div class="ggrid" id="g-all"></div>
        </div>

        <!-- HOT -->
        <div class="page" id="page-hot">
          <div class="sh"><span class="sh-label">🔥 Hot Right Now</span></div>
          <div class="ggrid" id="g-hot"></div>
        </div>

        <!-- CATEGORY PAGES -->
        <div class="page" id="page-action"><div class="sh"><span class="sh-label">⚔️ Action</span></div><div class="ggrid" id="g-action"></div></div>
        <div class="page" id="page-racing"><div class="sh"><span class="sh-label">🏎️ Racing</span></div><div class="ggrid" id="g-racing"></div></div>
        <div class="page" id="page-sports"><div class="sh"><span class="sh-label">🏈 Sports</span></div><div class="ggrid" id="g-sports"></div></div>
        <div class="page" id="page-puzzle"><div class="sh"><span class="sh-label">🧩 Puzzle</span></div><div class="ggrid" id="g-puzzle"></div></div>
        <div class="page" id="page-io"><div class="sh"><span class="sh-label">🌐 .io Games</span></div><div class="ggrid" id="g-io"></div></div>
        <div class="page" id="page-idle"><div class="sh"><span class="sh-label">🍪 Idle / Clicker</span></div><div class="ggrid" id="g-idle"></div></div>
        <div class="page" id="page-classic"><div class="sh"><span class="sh-label">🕹️ Classic</span></div><div class="ggrid" id="g-classic"></div></div>

        <!-- SEARCH -->
        <div class="page" id="page-search">
          <div class="sh"><span class="sh-label">Search</span><span class="sh-sub" id="sCnt"></span></div>
          <div class="ggrid" id="g-search"></div>
        </div>

        <!-- SETTINGS -->
        <div class="page" id="page-settings">
          <div class="sset">
            <div class="sset-title">Profile</div>
            <div class="srow">Display Name <span><input class="s-input" id="sNIn" maxlength="20"></span></div>
            <button class="sbtn" onclick="saveName()">Save Changes</button>
          </div>
          <div class="sset">
            <div class="sset-title">Background Theme</div>
            <div class="bg-grid-s" id="bgSet"></div>
          </div>
        </div>

      </div><!-- /content -->

      <!-- GAME VIEW -->
      <div id="gview">
        <div class="gbar">
          <button class="gbar-back" onclick="closeGame()">← Back</button>
          <span class="gbar-title" id="gTitle"></span>
          <button class="gbar-fs" onclick="goFS()">⛶ Fullscreen</button>
        </div>
        <iframe id="gframe" src="" allowfullscreen></iframe>
      </div>

    </div>
  </div>
</div>

<script>
/* ════════ GAME DATABASE ════════ */
const G=[
  // Action / Runners
  {id:'slope',     name:'Slope',               emoji:'⛰️', tag:'Endless Runner · Skill',   cat:'action', hot:1, feat:1, url:'https://slope.game'},
