  // Racing
  {id:'madalin',   name:'Madalin Stunt Cars 2', emoji:'🏎️', tag:'Racing · Stunts',         cat:'racing', hot:1, url:'https://madalinstuntcars2.com'},
  {id:'drift',     name:'Drift Boss',           emoji:'🌀', tag:'Racing · Drift',           cat:'racing', hot:1, url:'https://driftboss.io'},
  {id:'getaway',   name:'Getaway Shootout',     emoji:'🏃', tag:'Racing · Chaos',           cat:'racing', hot:0, url:'https://www.crazygames.com/game/getaway-shootout'},
  {id:'roadrush',  name:'Road Rush Cars',       emoji:'🚗', tag:'Racing · Endless',         cat:'racing', hot:0, url:'https://www.crazygames.com/game/road-rush-cars'},
  {id:'happywheel',name:'Happy Wheels',         emoji:'🩸', tag:'Racing · Physics',         cat:'racing', hot:1, url:'https://www.totaljerkface.com/happy_wheels.tjf'},
  // Sports
  {id:'retrobowl', name:'Retro Bowl',           emoji:'🏈', tag:'Sports · Football',        cat:'sports', hot:1, feat:1, url:'https://retrobowl.me'},
  {id:'bball',     name:'Basketball Stars',     emoji:'🏀', tag:'Sports · Basketball',      cat:'sports', hot:1, url:'https://www.miniclip.com/games/basketball-stars'},
  {id:'soccer',    name:'Soccer Random',        emoji:'⚽', tag:'Sports · Soccer',          cat:'sports', hot:0, url:'https://www.crazygames.com/game/soccer-random'},
  {id:'hockey',    name:'Hockey Random',        emoji:'🏒', tag:'Sports · Hockey',          cat:'sports', hot:0, url:'https://www.crazygames.com/game/hockey-random'},
  {id:'golf',      name:'Golf Orbit',           emoji:'⛳', tag:'Sports · Golf',            cat:'sports', hot:0, url:'https://www.crazygames.com/game/golf-orbit'},
  // Puzzle
  {id:'2048',      name:'2048',                 emoji:'🔢', tag:'Puzzle · Numbers',         cat:'puzzle', hot:1, url:'https://play2048.co'},
  {id:'tetris',    name:'Tetris',               emoji:'🟦', tag:'Puzzle · Classic',         cat:'puzzle', hot:1, url:'https://tetris.com/play-tetris'},
  {id:'wordle',    name:'Wordle',               emoji:'🟩', tag:'Puzzle · Word',            cat:'puzzle', hot:1, url:'https://www.nytimes.com/games/wordle'},
  {id:'cubefield', name:'Cube Field',           emoji:'🎲', tag:'Puzzle · Dodge',           cat:'puzzle', hot:0, url:'https://www.crazygames.com/game/cube-field'},
  {id:'bloxorz',   name:'Bloxorz',              emoji:'🟫', tag:'Puzzle · Logic',           cat:'puzzle', hot:0, url:'https://www.coolmathgames.com/0-bloxorz'},
  // .io
  {id:'agar',      name:'Agar.io',              emoji:'🟢', tag:'.io · Grow & Eat',         cat:'io',     hot:1, url:'https://agar.io'},
  {id:'slither',   name:'Slither.io',           emoji:'🐍', tag:'.io · Snake',              cat:'io',     hot:1, url:'https://slither.io'},
  {id:'diep',      name:'Diep.io',              emoji:'🔵', tag:'.io · Tank Shooter',       cat:'io',     hot:1, url:'https://diep.io'},
  {id:'paper',     name:'Paper.io 2',           emoji:'📄', tag:'.io · Territory',          cat:'io',     hot:0, url:'https://paper-io.com'},
  {id:'wings',     name:'Wings.io',             emoji:'✈️', tag:'.io · Air Combat',         cat:'io',     hot:0, url:'https://wings.io'},
  {id:'mope',      name:'Mope.io',              emoji:'🦁', tag:'.io · Animal Survival',    cat:'io',     hot:0, url:'https://mope.io'},
  {id:'brutal',    name:'Brutal.io',            emoji:'🔗', tag:'.io · Flail',              cat:'io',     hot:0, url:'https://brutal.io'},
  // Idle
  {id:'cookie',    name:'Cookie Clicker',       emoji:'🍪', tag:'Idle · Clicker',           cat:'idle',   hot:1, feat:1, url:'https://orteil.dashnet.org/cookieclicker'},
  {id:'adcap',     name:'AdVenture Capitalist', emoji:'💰', tag:'Idle · Business',          cat:'idle',   hot:1, url:'https://www.crazygames.com/game/adventure-communist'},
  {id:'realm',     name:'Realm Grinder',        emoji:'⚔️', tag:'Idle · RPG',              cat:'idle',   hot:0, url:'https://www.kongregate.com/games/rubycookies/realm-grinder'},
  // Classic
  {id:'pacman',    name:'Pac-Man',              emoji:'👻', tag:'Classic · Arcade',         cat:'classic',hot:1, url:'https://www.google.com/search?q=play+pac+man'},
  {id:'mario',     name:'Super Mario Bros',     emoji:'🍄', tag:'Classic · Platformer',     cat:'classic',hot:1, url:'https://supermario-game.com'},
  {id:'minecraft', name:'Minecraft Classic',    emoji:'⛏️', tag:'Classic · Sandbox',       cat:'classic',hot:1, url:'https://classic.minecraft.net'},
  {id:'snake',     name:'Snake Game',           emoji:'🐍', tag:'Classic · Arcade',         cat:'classic',hot:0, url:'https://www.google.com/search?q=play+snake+game'},
  {id:'spaceinv',  name:'Space Invaders',       emoji:'👾', tag:'Classic · Shooter',        cat:'classic',hot:0, url:'https://www.crazygames.com/game/space-invaders'},
  {id:'donkey',    name:'Donkey Kong',          emoji:'🦍', tag:'Classic · Arcade',         cat:'classic',hot:0, url:'https://www.crazygames.com/game/donkey-kong'},
];

const BGS=[
  {e:'🔥',l:'Ember',  v:'linear-gradient(135deg,#0E0800 0%,#3D1E00 50%,#1A0F00 100%)'},
  {e:'🌌',l:'Galaxy', v:'linear-gradient(135deg,#000510 0%,#001a3a 50%,#000c20 100%)'},
  {e:'💜',l:'Void',   v:'linear-gradient(135deg,#050010 0%,#1a0030 50%,#0a0018 100%)'},
  {e:'🌲',l:'Forest', v:'linear-gradient(135deg,#001505 0%,#003015 50%,#001508 100%)'},
  {e:'🖤',l:'Abyss',  v:'linear-gradient(135deg,#080808 0%,#181818 50%,#0c0c0c 100%)'},
  {e:'🌅',l:'Dusk',   v:'linear-gradient(135deg,#100500 0%,#301500 50%,#180a00 100%)'},
  {e:'🩵',l:'Ocean',  v:'linear-gradient(135deg,#000c18 0%,#00243a 50%,#000f20 100%)'},
  {e:'❤️',l:'Crimson',v:'linear-gradient(135deg,#150000 0%,#300008 50%,#1a0004 100%)'},
  {e:'🟡',l:'Gold',   v:'linear-gradient(135deg,#120c00 0%,#2e2000 50%,#1a1200 100%)'},
  {e:'🌸',l:'Rose',   v:'linear-gradient(135deg,#150010 0%,#300028 50%,#1a0018 100%)'},
];

let userName='Player', selBg=BGS[0].v, curPage='home';

/* ── CURSOR ── */
const CE=document.getElementById('C'), CR=document.getElementById('CR');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;CE.style.left=mx+'px';CE.style.top=my+'px'});
(function ar(){rx+=(mx-rx)*.15;ry+=(my-ry)*.15;CR.style.left=rx+'px';CR.style.top=ry+'px';requestAnimationFrame(ar)})();

/* ── EMBERS ── */
const fb=document.getElementById('FB');
['#FF5C00','#FF8A00','#FFAA00','#C93D00','#FF6B1A'].forEach((c,_,a)=>{
  for(let i=0;i<10;i++){
    const e=document.createElement('div');e.className='ember';
    const s=1.5+Math.random()*4,dur=4+Math.random()*9,del=Math.random()*10;
    const dx=(Math.random()-.5)*90+'px',dx2=(Math.random()-.5)*130+'px';
    e.style.cssText=`left:${Math.random()*100}%;width:${s}px;height:${s}px;animation-duration:${dur}s;animation-delay:${del}s;background:${a[Math.floor(Math.random()*a.length)]};--dx:${dx};--dx2:${dx2}`;
    fb.appendChild(e);
  }
});

/* ── ONBOARDING ── */
let step=0;
document.getElementById('ob0').onclick=e=>{ if(e.altKey)enterApp(); else goStep(1); };
document.addEventListener('keydown',e=>{ if(e.altKey&&step<4)enterApp(); });

const nIn=document.getElementById('nIn'), nBtn=document.getElementById('nBtn');
nIn.addEventListener('input',()=>nBtn.disabled=!nIn.value.trim());
nIn.addEventListener('keydown',e=>{ if(e.key==='Enter'&&nIn.value.trim())toOb2(); });

// Build BG picker in onboarding
const bp=document.getElementById('bgPick');
BGS.slice(0,6).forEach((b,i)=>{
  const d=document.createElement('div');
  d.className='bg-opt'+(i===0?' sel':'');
  d.style.background=b.v;
  d.dataset.v=b.v;
  d.textContent=b.e;
  d.onclick=()=>{ document.querySelectorAll('.bg-opt').forEach(x=>x.classList.remove('sel')); d.classList.add('sel'); selBg=b.v; };
  bp.appendChild(d);
});

function goStep(n){ document.getElementById('ob'+step).classList.remove('active'); step=n; document.getElementById('ob'+n).classList.add('active'); }
function toOb2(){ userName=nIn.value.trim()||'Player'; document.getElementById('rName').textContent=userName.toUpperCase(); goStep(2); }
function toOb3(){ goStep(3); }
function enterApp(){
  const ob=document.getElementById('onboarding');
  ob.style.opacity='0';
  setTimeout(()=>{ ob.style.display='none'; document.getElementById('app').classList.add('show'); initApp(); },500);
}

/* ── APP INIT ── */
function initApp(){
  document.body.style.background=selBg;
  document.getElementById('sbN').textContent=userName;
  document.getElementById('sbAv').textContent=userName[0].toUpperCase();
  document.getElementById('sNIn').value=userName;

  // marquee
  const items=G.map(g=>`<span class="m-item">${g.emoji} ${g.name}</span>`).join('');
  document.getElementById('mTrk').innerHTML=items+items;

  // grids
  fillGrid('g-home',   G.filter(g=>g.hot).slice(0,12));
  fillGrid('g-new',    [...G].reverse().slice(0,8));
  fillGrid('g-all',    G);
  fillGrid('g-hot',    G.filter(g=>g.hot));
  fillGrid('g-action', G.filter(g=>g.cat==='action'));
  fillGrid('g-racing', G.filter(g=>g.cat==='racing'));
  fillGrid('g-sports', G.filter(g=>g.cat==='sports'));
  fillGrid('g-puzzle', G.filter(g=>g.cat==='puzzle'));
  fillGrid('g-io',     G.filter(g=>g.cat==='io'));
  fillGrid('g-idle',   G.filter(g=>g.cat==='idle'));
  fillGrid('g-classic',G.filter(g=>g.cat==='classic'));

  // featured card — random featured game
  const feats=G.filter(g=>g.feat);
  const f=feats[Math.floor(Math.random()*feats.length)];
  document.getElementById('featBg').textContent=f.emoji;
  document.getElementById('featName').textContent=f.name.toUpperCase();
  document.getElementById('featGenre').textContent=f.tag;
  const fc=document.getElementById('featCard');
  fc.onclick=()=>launchGame(f.id);
  const fpBtn=document.getElementById('fpBtn');
  fc.addEventListener('mouseenter',()=>{ fpBtn.style.opacity='1'; fpBtn.style.transform='scale(1)'; });
  fc.addEventListener('mouseleave',()=>{ fpBtn.style.opacity='0'; fpBtn.style.transform='scale(.88)'; });

  // settings bg grid
  const bgs=document.getElementById('bgSet');
  BGS.forEach(b=>{
    const d=document.createElement('div');
    d.className='bgo'+(b.v===selBg?' sel':'');
    d.style.background=b.v;
    d.textContent=b.e;
    d.title=b.l;
    d.onclick=()=>{ document.querySelectorAll('.bgo').forEach(x=>x.classList.remove('sel')); d.classList.add('sel'); selBg=b.v; document.body.style.background=b.v; };
    bgs.appendChild(d);
  });
}

/* ── GRID BUILDER ── */
function fillGrid(id,games){
  const el=document.getElementById(id); if(!el)return;
  el.innerHTML=games.map(g=>`
    <div class="gc" onclick="launchGame('${g.id}')">
      <div class="gc-thumb">
        <span>${g.emoji}</span>
        <div class="gc-play"><div class="gc-playbtn">▶</div></div>
      </div>
      ${g.hot?'<div class="gc-hot">Hot</div>':''}
      <div class="gc-info">
        <div class="gc-name">${g.name}</div>
        <div class="gc-tag">${g.tag}</div>
      </div>
    </div>`).join('');
}

/* ── LAUNCH ── */
function launchGame(id){
  const g=G.find(x=>x.id===id); if(!g)return;
  document.getElementById('gTitle').textContent=g.emoji+' '+g.name;
  document.getElementById('gframe').src=g.url;
  document.getElementById('content').style.display='none';
  document.getElementById('gview').classList.add('on');
}
function closeGame(){
  document.getElementById('gframe').src='';
  document.getElementById('gview').classList.remove('on');
  document.getElementById('content').style.display='';
}
function goFS(){ const f=document.getElementById('gframe'); if(f.requestFullscreen)f.requestFullscreen(); }

/* ── NAV ── */
function nav(name,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.sb-item').forEach(i=>i.classList.remove('on'));
  const pg=document.getElementById('page-'+name);
  if(pg)pg.classList.add('on');
  if(el)el.classList.add('on');
  curPage=name;
  closeGame();
  document.getElementById('content').style.display='';
}

/* ── SEARCH ── */
function doSearch(v){
  if(!v.trim()){ nav(curPage==='search'?'home':curPage,null); return; }
  const q=v.toLowerCase();
  const r=G.filter(g=>g.name.toLowerCase().includes(q)||g.tag.toLowerCase().includes(q)||g.cat.toLowerCase().includes(q));
  document.getElementById('sCnt').textContent=r.length+' result'+(r.length!==1?'s':'');
  fillGrid('g-search',r);
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.getElementById('page-search').classList.add('on');
}

/* ── SETTINGS ── */
function saveName(){
  const n=document.getElementById('sNIn').value.trim(); if(!n)return;
  userName=n;
  document.getElementById('sbN').textContent=n;
  document.getElementById('sbAv').textContent=n[0].toUpperCase();
  const b=document.querySelector('.sbtn');
  b.textContent='Saved ✓'; setTimeout(()=>b.textContent='Save Changes',1800);
}
</script>
</body>
</html>
